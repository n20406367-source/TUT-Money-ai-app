rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - nid: string
    //   - address: string
    //   - occupation: string
    //   - phone: string (required)
    //   - status: string (pending, approved)
    //   - memberId: string
    //   - totalLoan: number
    //   - totalDeposit: number
    //   - remainingDebt: number
    //   - role: string (admin, member)
    //
    // Collection: transactions
    // Fields:
    //   - userId: string (required)
    //   - type: string (loan, deposit)
    //   - amount: number (required)
    //   - status: string (pending, confirmed)
    //   - timestamp: timestamp (required)
    //   - memoId: string
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          request.auth.token.email == "tahsinullahtusher999@gmail.com" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'phone', 'status', 'role']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.size() >= 11 && data.phone.size() <= 15 &&
             data.status in ['pending', 'approved'] &&
             data.role in ['admin', 'member'] &&
             (!('nid' in data) || (data.nid is string && data.nid.size() <= 20)) &&
             (!('address' in data) || (data.address is string && data.address.size() <= 200)) &&
             (!('occupation' in data) || (data.occupation is string && data.occupation.size() <= 100)) &&
             (!('memberId' in data) || (data.memberId is string && data.memberId.size() <= 40)) &&
             (!('totalLoan' in data) || data.totalLoan is number) &&
             (!('totalDeposit' in data) || data.totalDeposit is number) &&
             (!('remainingDebt' in data) || data.remainingDebt is number) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'type', 'amount', 'method', 'status', 'timestamp']) &&
             data.userId is string &&
             data.type in ['loan', 'deposit', 'refund', 'pay_due'] &&
             data.amount is number && data.amount > 0 && data.amount < 100000000 &&
             data.method in ['Cash', 'Bkash', 'Nagad', 'Recharge'] &&
             data.status in ['pending', 'confirmed'] &&
             (!('accountNumber' in data) || (data.accountNumber is string && data.accountNumber.size() < 50)) &&
             (!('transactionId' in data) || (data.transactionId is string && data.transactionId.size() < 100)) &&
             (!('userName' in data) || (data.userName is string && data.userName.size() < 100)) &&
             (!('memoId' in data) || (data.memoId is string && data.memoId.size() < 50));
    }

    match /users/{userId} {
      allow read, list: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'member' || (request.resource.data.role == 'admin' && isAdmin()));
      allow update: if isAuthenticated() && (
        (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.status == resource.data.status) ||
        isAdmin()
      ) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read, list: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidTransaction(request.resource.data) && request.resource.data.status == 'pending';
      allow update: if isAdmin() && isValidTransaction(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
